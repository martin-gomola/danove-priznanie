# Daňové priznanie - DPFO typ B 2025
# Copy to .env before deploy (matches homelab-services layout)

# Port (host)
SERVICE_PORT=3015

# Timezone
TZ=Europe/Bratislava

# Per-session API tokens are auto-generated in the browser (no server-side config needed).
# Each user gets a unique session token stored in localStorage.

# Analytics (optional). If both are set, a tracker <script> is rendered in <head>.
# Read at build time, so each deploy bakes its own values.
# NEXT_PUBLIC_ANALYTICS_SRC=
# NEXT_PUBLIC_ANALYTICS_ID=
